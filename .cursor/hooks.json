{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/format-after-edit.sh",
        "matcher": "Write|TabWrite"
      },
      {
        "command": ".cursor/hooks/eslint-after-edit.sh",
        "matcher": "Write|TabWrite"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/guard-secrets.sh",
        "matcher": "UserPromptSubmit"
      }
    ]
  }
}
